# NullTrace Configuration
# Set your API keys here to enable professional features

# HaveIBeenPwned API Key (to enable deep breach lookups)
HIBP_API_KEY=your_hibp_key_here

# Truecaller Session Token (to enable authenticated phone lookups)
# You can get this from the browser's DevTools while logged into Truecaller Web
TRUECALLER_TOKEN=your_truecaller_token_here

# Other potential integrations
# GITHUB_TOKEN=your_github_personal_access_token
